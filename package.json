{
  "name": "fern",
  "version": "0.1.4",
  "description": "Fern Markdown Editor",
  "main": "dist-electron/main.js",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "preview": "electron .",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir"
  },
  "build": {
    "appId": "app.fern.editor",
    "productName": "Fern",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": "nsis",
      "artifactName": "Fern-Setup.exe"
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Fern",
        "description": "Fern",
        "role": "Editor"
      }
    ],
    "mac": {
      "icon": "assets/icon.png",
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": "AppImage",
      "category": "Development"
    },
    "publish": {
      "provider": "github",
      "owner": "lewisjb337",
      "repo": "fern",
      "releaseType": "release"
    },
    "npmRebuild": false
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.10.8",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.35.3",
    "@fontsource/inter": "^5.1.1",
    "@lezer/highlight": "^1.2.1",
    "@octokit/rest": "^22.0.1",
    "@replit/codemirror-vim": "^6.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "chart.js": "^4.5.1",
    "chokidar": "^3.6.0",
    "codemirror": "^6.0.1",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.4",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0",
    "mermaid": "^11.16.0",
    "node-pty": "^1.1.0",
    "papaparse": "^5.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^20.17.57",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "electron": "^33.4.4",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^5.0.0",
    "sharp": "^0.35.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
